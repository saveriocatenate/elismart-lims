# EliSmart LIMS — Environment Variables
#
# Copy this file to .env and fill in the values.
# Source it before starting the backend: source .env
#
# NEVER commit .env or any file containing real credentials.

# ---------------------------------------------------------------------------
# Backend (Spring Boot)
# ---------------------------------------------------------------------------

# Google Gemini API key — required for POST /api/ai/analyze
# Obtain from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional override (default shown)
# GEMINI_MODEL=gemini-2.0-flash

# Gemini HTTP read timeout in milliseconds. Default: 120000 (120 seconds).
# Increase for very large prompts or slow network links.
# GEMINI_TIMEOUT_MS=120000

# Spring profile to activate (dev uses H2 file-based DB)
# SPRING_PROFILES_ACTIVE=dev

# JWT secret key — required. Minimum 32 characters.
# Generate a strong value with: openssl rand -base64 32
# The application will refuse to start if this is missing, blank, or too short.
JWT_SECRET=

# JWT token expiration in milliseconds. Default: 86400000 (24 hours).
# Shorten for higher security, lengthen for less frequent re-login.
# JWT_EXPIRATION_MS=86400000

# CORS allowed origin for the frontend. Default: http://localhost:8501
# Change this if accessing the backend from a tunnel URL, remote host,
# or different port. Example for a Pinggy tunnel:
# CORS_ALLOWED_ORIGIN=https://abcd1234.pinggy.link
CORS_ALLOWED_ORIGIN=

# Admin password for the first-boot user seeding.
# If set and non-empty, the admin user is created with this password (BCrypt-hashed).
# If unset or empty, a cryptographically random 16-character password is generated
# and printed ONLY to stdout at startup (never to log files).
# Ignored on subsequent starts when the database already contains users.
# ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# Frontend (Streamlit)
# ---------------------------------------------------------------------------
# These are normally set in frontend/.streamlit/secrets.toml (gitignored).
# They can also be provided as environment variables.

# URL of the running Spring Boot backend
BACKEND_URL=http://localhost:8080

# (Streamlit auth gate is now JWT-based via /api/auth/login — no static credentials needed here)
