# EliSmart LIMS — Environment Variables
#
# Copy this file to .env and fill in the values.
# Source it before starting the backend: source .env
#
# NEVER commit .env or any file containing real credentials.

# ---------------------------------------------------------------------------
# Backend (Spring Boot)
# ---------------------------------------------------------------------------

# Google Gemini API key — required for POST /api/ai/analyze
# Obtain from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional override (default shown)
# GEMINI_MODEL=gemini-2.0-flash

# Spring profile to activate (dev uses H2 file-based DB)
# SPRING_PROFILES_ACTIVE=dev

# ---------------------------------------------------------------------------
# Frontend (Streamlit)
# ---------------------------------------------------------------------------
# These are normally set in frontend/.streamlit/secrets.toml (gitignored).
# They can also be provided as environment variables.

# URL of the running Spring Boot backend
BACKEND_URL=http://localhost:8080

# Login credentials for the Streamlit auth gate
LOGIN_USER=admin
# bcrypt hash of the password — generate with:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
LOGIN_PASS=$2b$12$...your_bcrypt_hash_here...
